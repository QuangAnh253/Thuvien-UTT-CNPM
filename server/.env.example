# Backend Environment Variables

# Production (Render)
# Set these in Render Dashboard → Settings → Environment Variables
# Recommended: comma-separated list of allowed frontend origins
# Example: ALLOWED_ORIGINS=https://your-frontend-url.vercel.app,https://preview-your-frontend.vercel.app
ALLOWED_ORIGINS=https://your-frontend-url.vercel.app

# Backward compatibility (optional if ALLOWED_ORIGINS is set)
FRONTEND_URL=https://your-frontend-url.vercel.app
PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://your-user:your-password@dpg-xxx/your-database

# Development (Local)
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
DATABASE_URL=file:./prisma/dev.db

# JWT/Auth secrets (if needed)
# JWT_SECRET=your_secret_key

# Resend OTP Email
# Domain da verify: lequanganh.id.vn
# OTP_FROM_EMAIL nen dung dang: no-reply@lequanganh.id.vn
RESEND_API_KEY=re_xxxxxxxxx
OTP_FROM_EMAIL=no-reply@lequanganh.id.vn
OTP_APP_NAME=Thu vien UTT